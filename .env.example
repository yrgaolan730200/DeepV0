# ============================================
# vSeek — Environment Variables
# ============================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
# ============================================

# ---- DeepSeek API (required for P1 generation) ----
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# DeepSeek model configuration
# Model for code generation (default: deepseek-v4-pro)
DEEPSEEK_MODEL=deepseek-v4-pro
# Faster model for simple tasks (default: deepseek-v4-flash)
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
# API endpoint (default: https://api.deepseek.com)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---- Server Configuration ----
SERVER_PORT=3001
SERVER_HOST=0.0.0.0

# ---- Logging ----
LOG_LEVEL=info
NODE_ENV=development

# ---- Anthropic API (optional — P3 Claude escalation) ----
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
